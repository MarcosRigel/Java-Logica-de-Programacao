import java.util.Scanner;

public class Main {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int x = sc.nextInt();
		System.out.println(x);
		
		int divisao1 = x / 100;
		System.out.println(divisao1);
		int rest1 = x % 100;
		
		int divisao2 = rest1 / 50;
		System.out.println(divisao2);
		int rest2 = x % 50;	
		
		int divisao3 = rest2 / 20;
		System.out.println(divisao3);
		int rest3 = x % 20;
		
		int divisao4 = rest3 / 10;
		System.out.println(divisao4);
		int rest4 = rest3 % 10;
		
		int divisao5 = rest4 / 5;
		System.out.println(divisao5);
		int rest5 = x % 5;
		
		int divisao6 = rest5 / 2;
		System.out.println(divisao6);
		
		sc.close();
	}

}
